# Essential
source ~/.zplug/init.zsh
SHOW_AWS_PROMPT=false
zplug "greymd/tmux-xpanes"
zplug "plugins/aws",   from:oh-my-zsh
zplug "MichaelAquilina/zsh-you-should-use"
zplug "plugins/git",   from:oh-my-zsh
#zplug "plugins/gitignore",   from:oh-my-zsh # Hardly use it and gets in the way of autocorrecting gi to git :)
zplug "plugins/dircycle",   from:oh-my-zsh
zplug "plugins/knife",   from:oh-my-zsh
zplug "plugins/kitchen",   from:oh-my-zsh
zplug "plugins/ripgrep",   from:oh-my-zsh
zplug "plugins/tmux",   from:oh-my-zsh
zplug "plugins/tmuxinator",   from:oh-my-zsh
zplug "plugins/vi-mode",   from:oh-my-zsh
zplug "plugins/command-not-found",   from:oh-my-zsh
zplug "plugins/gem", from:oh-my-zsh
zplug "plugins/chruby", from:oh-my-zsh
zplug "plugins/brew", from:oh-my-zsh
zplug "plugins/zsh-navigation-tools", from:oh-my-zsh
zplug "plugins/ubuntu", from:oh-my-zsh, if:"[[ $VENDOR == ubuntu ]]"
zplug "plugins/systemd", from:oh-my-zsh, if:"[[ $VENDOR == ubuntu ]]"
zplug "lib/directories", from:oh-my-zsh
zplug "lib/grep", from:oh-my-zsh
zplug "plugins/osx", from:oh-my-zsh, if:"[[ $OSTYPE == *darwin* ]]"

zplug "zsh-users/zsh-syntax-highlighting", defer:2
zplug "plugins/history-substring-search", from:oh-my-zsh, defer:3
zplug "plugins/history", from:oh-my-zsh
zplug "plugins/fzf", from:oh-my-zsh
zplug "zsh-users/zsh-completions"
zplug "zsh-users/zsh-autosuggestions"

# Install plugins if there are plugins that have not been installed
if ! zplug check --verbose; then
    printf "Install? [y/N]: "
    if read -q; then
        echo; zplug install
    fi
fi

# Then, source plugins and add commands to $PATH
zplug load
