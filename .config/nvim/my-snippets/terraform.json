{
  "Set common tags": {
    "prefix": "tags",
    "body": [
      "tags = local.common_tags",
      "$0"
    ],
    "description": "Set common tags parameter"
  },
  "Create module call": {
    "prefix": "module",
    "body": [
      "module \"${1:module_name}\" {",
      "  source = \"git::https://git.enova.com/tf-modules/${2:module_source}?ref=v1.0.0\"",
      "}",
      "$0"
    ],
    "description": "Create a module call"
  }
}
